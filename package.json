{
  "name": "setup-pkl",
  "description": "GitHub Action for installing Pkl",
  "version": "0.0.9",
  "author": "The Pkl Community",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pkl-community/setup-pkl.git"
  },
  "bugs": {
    "url": "https://github.com/pkl-community/setup-pkl/issues"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "vitest run --coverage",
    "coverage": "make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "gen:actions": "pkl eval .github/pkl-workflows/*.pkl -o \".github/workflows/%{moduleName}.generated.yml\"",
    "lint": "eslint .",
    "package": "rimraf ./dist && tsx esbuild.config.ts && npm run gen:actions",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "all": "npm run format:write && npm run lint && npm run typecheck && npm run test && npm run coverage && npm run package"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "@actions/tool-cache": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/eslint-plugin": "^1.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jiti": "^2.0.0",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0",
    "vitest": "^3.0.0"
  }
}
